# Cloudflare / CDN Cache-Regeln

# Root-Level Ressourcen (Bilder, CSS, JS)
/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.mp4
  Cache-Control: public, max-age=86400

/index.html
  Cache-Control: public, max-age=3600, must-revalidate
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Referrer-Policy: strict-origin-when-cross-origin

/gebaeudereinigung-berlin/images/*
  Cache-Control: public, max-age=31536000, immutable

/gebaeudereinigung-berlin/*.webp
  Cache-Control: public, max-age=31536000, immutable

/gebaeudereinigung-berlin/*.png
  Cache-Control: public, max-age=31536000, immutable

/gebaeudereinigung-berlin/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/gebaeudereinigung-berlin/index.html
  Cache-Control: public, max-age=3600, must-revalidate
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Referrer-Policy: strict-origin-when-cross-origin
